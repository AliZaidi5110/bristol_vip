# =============================================================================
#  Bristol VIP — environment variables
#  Run `npm run setup` to auto-generate .env.local and DEPLOY-ENV.txt
# =============================================================================

# --- Required (admin + sessions) ----------------------------------------------
SESSION_SECRET=generate-with-npm-run-setup
# Easiest on Vercel (no bcrypt $ issues):
ADMIN_PASSWORD=your-secret-password
# Or bcrypt hash from npm run setup:
# ADMIN_PASSWORD_HASH=generate-with-npm-run-setup

# --- Ticket link (works without any database) ---------------------------------
TICKET_LINK=https://www.eventbrite.co.uk/

# --- Vercel KV (recommended for live admin editing on Vercel) -----------------
# Added automatically when you create a KV store: Vercel → Storage → KV → Connect
# KV_REST_API_URL=
# KV_REST_API_TOKEN=

# --- Contact form (Resend) ----------------------------------------------------
# 1) Sign up at https://resend.com with bristolvip1@gmail.com (important!)
# 2) API Keys → Create → copy re_...
# 3) Put the same values in Vercel → Settings → Environment Variables → Redeploy
#
# Sandbox rule: with onboarding@resend.dev, Resend can ONLY deliver to the
# email address that owns the Resend account. To send to any inbox, verify a
# domain at https://resend.com/domains and change CONTACT_FROM_EMAIL.
RESEND_API_KEY=re_xxxxxxxx
CONTACT_TO_EMAIL=bristolvip1@gmail.com
CONTACT_FROM_EMAIL=Bristol VIP Website <onboarding@resend.dev>
# Optional: used as Origin for FormSubmit fallback
# NEXT_PUBLIC_SITE_URL=https://bristol-vip-pi.vercel.app

# GITHUB_TOKEN=re_xxxxxxxx  # optional — saves events to data/site-event.json in GitHub
# NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
