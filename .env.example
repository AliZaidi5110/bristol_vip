# =============================================================================
#  Bristol VIP — environment variables
#  Copy this file to `.env.local` and fill in the real values.
#  NEVER commit .env.local. Set the same vars in Vercel → Project → Settings →
#  Environment Variables for production.
# =============================================================================

# --- Supabase -----------------------------------------------------------------
# From Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Service role key — SERVER ONLY. Never expose to the browser / never prefix
# with NEXT_PUBLIC. Used by admin API routes to write to the database.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Admin auth ---------------------------------------------------------------
# bcrypt hash of your admin password. Generate it with:
#   npm run hash-password "your-password"
# Wrap the value in single quotes because bcrypt hashes contain $ characters.
ADMIN_PASSWORD_HASH='$2a$12$replace_me_with_a_real_generated_hash'

# Secret used to sign the admin session cookie (JWT). Use a long random string.
# Generate one with:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=change-me-to-a-long-random-string-at-least-32-chars
